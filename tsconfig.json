{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "moduleResolution": "node",
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "styled-system/*": ["./styled-system/*"],
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "styled-system"]
}
