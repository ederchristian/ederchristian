---
interface Props {
  title: string
  subtitle?: string
}

const { title, subtitle } = Astro.props
---

<header class="page-header">
  <h1>{title}</h1>
  {subtitle ? <p class="page-header__subtitle">{subtitle}</p> : null}
  <slot />
</header>

<style>
  .page-header {
    margin: 0 0 40px;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 8px;
    line-height: var(--lh-heading);
  }
  .page-header__subtitle {
    color: var(--text-secondary);
    margin: 0;
    font-size: var(--fs-body);
    line-height: var(--lh-base);
  }
</style>
