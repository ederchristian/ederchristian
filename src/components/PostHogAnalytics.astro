---
const phKey = import.meta.env.PUBLIC_POSTHOG_KEY
const phHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? "https://us.i.posthog.com"
const enabled =
  import.meta.env.PROD || import.meta.env.PUBLIC_POSTHOG_ENABLED === "true"
const shouldLoad = enabled && Boolean(phKey)
---

{
  shouldLoad ? (
    <script is:inline define:vars={{ phKey, phHost }}>
      import("https://us.i.posthog.com/static/array.js").then(() => {
        window.posthog.init(phKey, {
          api_host: phHost,
          capture_pageview: false,
          capture_pageleave: true,
          autocapture: true,
          persistence: "localStorage+cookie",
        })
        window.posthog.capture("$pageview")

        document.addEventListener("astro:after-swap", () => {
          window.posthog.capture("$pageview")
        })
      })
    </script>
  ) : null
}
