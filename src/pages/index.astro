---
import { ArrowRight, ArrowUpRight } from "lucide-astro"
import NewsletterForm from "../components/NewsletterForm.astro"
import { NOW_LAST_UPDATED, SITE_DESCRIPTION } from "../consts"
import PageLayout from "../layouts/PageLayout.astro"
import { getGardenNotes, getRecentWriting } from "../lib/content"
import { GARDEN_THEMES } from "../lib/themes"

const recent = await getRecentWriting(3)
const gardenNotes = await getGardenNotes()
const countByTheme = (slug: string) =>
  gardenNotes.filter((n) => n.data.theme === slug).length

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" })

const nowBullets = [
  "Frontend engineer on the Sync team at Automatiq, heading toward Product Engineer with a performance focus.",
  "Writing at Inner Commit on Substack. English-only since the pivot.",
  "Building Perspion under WheyDev, my side project for small, focused products in my free time.",
  "Reading Word Power Made Easy and The Pragmatic Programmer.",
  "Jiu jitsu three times a week (white belt). Gym the other three days.",
  "At home in Londrina, Brazil with Natalia and our new Boston Terrier, Ashley.",
]
---

<PageLayout title="Eder Christian" description={SITE_DESCRIPTION} titleTag="Eder Christian, frontend engineer writing in public">
  <section class="hero container">
    <p class="hero__eyebrow">Product-minded frontend engineer · remote from Brazil</p>
    <h1 class="hero__title">I came from outside the tech bubble.</h1>
    <p class="hero__body">
      No Silicon Valley origin story. A secondhand MacBook, discipline, and a quiet will to keep going. Today I work remotely for a New York company and write about the road from here to there.
    </p>
    <div class="hero__form">
      <NewsletterForm />
    </div>
  </section>

  <section class="section container">
    <header class="section__head">
      <h2>Things I'm Building</h2>
      <span class="section__sub">under <a href="https://whey.dev" target="_blank" rel="noopener noreferrer">WheyDev LLC</a></span>
    </header>
    <article class="product">
      <div class="product__head">
        <h3>Perspion</h3>
        <span class="product__badge">MVP</span>
      </div>
      <p class="product__desc">Mines YouTube comments for content ideas, questions, and sentiment.</p>
      <div class="product__stack">
        <span>Next.js</span>
        <span>TypeScript</span>
        <span>Gemini</span>
      </div>
      <a class="product__link" href="https://perspion.whey.dev" target="_blank" rel="noopener noreferrer">
        perspion.whey.dev <ArrowUpRight size={14} />
      </a>
    </article>
  </section>

  <section class="section container">
    <header class="section__head">
      <h2>Recent Writing</h2>
      <a href="/writing" class="section__cta">all <ArrowRight size={14} /></a>
    </header>
    <ul class="recent">
      {
        recent.map((post) => (
          <li>
            <a href={`/writing/${post.slug}`}>
              <span class="recent__title">{post.data.title}</span>
              <span class="recent__date">{formatDate(new Date(post.data.date))}</span>
            </a>
          </li>
        ))
      }
      {recent.length === 0 ? <li class="recent__empty">No posts yet.</li> : null}
    </ul>
  </section>

  <section class="section container">
    <header class="section__head">
      <h2>Garden</h2>
      <span class="section__sub">A public second brain</span>
    </header>
    <div class="theme-grid">
      {
        GARDEN_THEMES.map((theme) => {
          const Icon = theme.icon
          const count = theme.slug === "uses" ? null : countByTheme(theme.slug)
          return (
            <a class="theme-card" href={theme.href}>
              <Icon size={18} class="theme-card__icon" />
              <span class="theme-card__name">{theme.name}</span>
              {count !== null ? (
                <span class="theme-card__count">{count} {count === 1 ? "note" : "notes"}</span>
              ) : (
                <span class="theme-card__count">page</span>
              )}
            </a>
          )
        })
      }
    </div>
  </section>

  <section class="section container">
    <header class="section__head">
      <h2>Now</h2>
      <span class="section__sub">Updated {formatDate(new Date(NOW_LAST_UPDATED))}</span>
    </header>
    <ul class="now">
      {nowBullets.map((b) => <li>{b}</li>)}
    </ul>
    <a class="section__more" href="/now">Read the full Now page <ArrowRight size={14} /></a>
  </section>
</PageLayout>

<style>
  .hero {
    padding-top: 80px;
    padding-bottom: 64px;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
    margin: 0 0 24px;
  }
  .hero__title {
    font-family: var(--font-serif);
    font-size: var(--fs-display);
    font-weight: 400;
    line-height: var(--lh-display);
    color: var(--text-primary);
    margin: 0 0 24px;
  }
  .hero__body {
    font-size: var(--fs-lede);
    line-height: var(--lh-base);
    color: var(--text-secondary);
    margin: 0 0 32px;
    max-width: 580px;
  }
  .hero__form {
    max-width: 480px;
  }
  @media (max-width: 720px) {
    .hero { padding-top: 48px; }
    .hero__title { font-size: 40px; }
  }

  .section {
    padding-top: 40px;
    padding-bottom: 40px;
    border-top: 1px solid var(--border-subtle);
  }
  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 24px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section__head h2 {
    font-size: var(--fs-h2);
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
  }
  .section__sub {
    color: var(--text-tertiary);
    font-size: var(--fs-meta);
  }
  .section__sub a {
    color: var(--text-secondary);
  }
  .section__sub a:hover {
    color: var(--accent);
  }
  .section__cta,
  .section__more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-secondary);
    font-size: var(--fs-meta);
  }
  .section__cta:hover {
    color: var(--accent);
  }
  .section__more {
    margin-top: 16px;
    color: var(--accent);
  }

  .recent {
    list-style: none;
    padding: 0;
  }
  .recent li + li {
    border-top: 1px solid var(--border-subtle);
  }
  .recent a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    gap: 16px;
  }
  .recent__title {
    color: var(--text-primary);
    font-size: var(--fs-body);
    transition: color 200ms ease;
  }
  .recent a:hover .recent__title {
    color: var(--accent);
  }
  .recent__date {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    color: var(--text-tertiary);
    white-space: nowrap;
  }
  .recent__empty {
    color: var(--text-tertiary);
    padding: 14px 0;
    font-size: var(--fs-meta);
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (max-width: 560px) {
    .theme-grid { grid-template-columns: 1fr; }
  }
  .theme-card {
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 150ms ease, border-color 200ms ease;
  }
  .theme-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-emphasis);
    color: inherit;
  }
  .theme-card__icon {
    color: var(--accent);
  }
  .theme-card__name {
    color: var(--text-primary);
    font-size: var(--fs-body);
    font-weight: 500;
  }
  .theme-card__count {
    color: var(--text-tertiary);
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
  }

  .product {
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
    transition: transform 150ms ease, border-color 200ms ease;
  }
  .product:hover {
    transform: translateY(-2px);
    border-color: var(--border-emphasis);
  }
  .product__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 8px;
  }
  .product__head h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: var(--fs-h3);
    font-weight: 500;
  }
  .product__badge {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    color: var(--accent);
    border: 1px solid rgba(0, 213, 159, 0.4);
    background: rgba(0, 213, 159, 0.08);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .product__desc {
    margin: 0 0 16px;
    color: var(--text-secondary);
    font-size: var(--fs-body);
    line-height: var(--lh-base);
  }
  .product__stack {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0 0 16px;
  }
  .product__stack span {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    padding: 2px 8px;
  }
  .product__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent);
    font-size: var(--fs-meta);
  }

  .now {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .now li {
    color: var(--text-primary);
    font-size: var(--fs-body);
    line-height: var(--lh-base);
    padding-left: 20px;
    position: relative;
  }
  .now li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent);
  }
</style>
