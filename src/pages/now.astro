---
import PageHeader from "../components/PageHeader.astro"
import { NOW_LAST_UPDATED } from "../consts"
import PageLayout from "../layouts/PageLayout.astro"

const sections = [
  {
    title: "Work",
    body: "Frontend engineer on the Sync team at Automatiq. The part I care about most is the product side: analytics, NPS, getting close to users, turning data into decisions. AI is part of the daily flow now, and I document everything I touch. The direction I'm heading is Product Engineer with a focus on performance and data-heavy interfaces.",
  },
  {
    title: "Writing",
    body: "Inner Commit on Substack. I started years ago in Portuguese, then pivoted to English-only. Substack is where I get close to people; the site is for essays, announcements, and documentation. The gravity is engineering: performance, data, frontend craft. Career and lessons learned show up too, but the technical work leads.",
  },
  {
    title: "Building",
    body: "WheyDev is my side project, built in my free time. The idea is a one-engineer studio for small, focused software products shipped with production discipline. The name plays on \"whey\" (protein, strength, no fluff) and \"dev\". Perspion is the first product. Open source belongs here too.",
  },
  {
    title: "Reading",
    body: "Word Power Made Easy by Norman Lewis (a coworker recommended it). I've been teaching myself English since 2016 and still want sharper vocabulary and pronunciation. Also working through The Pragmatic Programmer.",
  },
  {
    title: "Studying",
    body: "AI and frontend courses on Frontend Masters. That's my main classroom right now.",
  },
  {
    title: "Training",
    body: "Jiu jitsu three times a week, still a white belt, no rush. Gym the other three days.",
  },
  {
    title: "Home",
    body: "Living in Londrina, in the south of Brazil, with my wife Natalia. We recently welcomed a Boston Terrier named Ashley to the house. She gets a line on this page because she's earned it.",
  },
  {
    title: "Watching",
    body: "Soccer is the first love. I support Palmeiras here in Brazil. This year I'm also following more NFL and NBA: 49ers are locked in, and I'm watching enough Warriors and Celtics games to pick a side.",
  },
]

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" })
---

<PageLayout title="Now" description="What I'm focused on right now.">
  <div class="container now-page">
    <PageHeader title="Now" subtitle="What I'm focused on right now." />

    {
      sections.map((s) => (
        <section class="now-section">
          <h2>{s.title}</h2>
          <p>{s.body}</p>
        </section>
      ))
    }

    <footer class="now-page__foot">
      <p class="now-page__updated">Updated {formatDate(new Date(NOW_LAST_UPDATED))}</p>
      <p>
        This page is part of the <a href="https://nownownow.com" target="_blank" rel="noopener noreferrer">/now movement</a>, started by Derek Sivers.
      </p>
    </footer>
  </div>
</PageLayout>

<style>
  .now-page {
    padding-top: 64px;
    padding-bottom: 32px;
  }
  .now-section {
    margin-bottom: 24px;
  }
  .now-section h2 {
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-family: var(--font-mono);
    margin: 0 0 8px;
  }
  .now-section p {
    color: var(--text-primary);
    line-height: var(--lh-base);
    margin: 0;
    font-size: var(--fs-body);
  }
  .now-page__foot {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border-subtle);
    color: var(--text-tertiary);
    font-size: var(--fs-meta);
  }
  .now-page__foot p {
    margin: 0 0 8px;
  }
  .now-page__foot p:last-child {
    margin-bottom: 0;
  }
  .now-page__updated {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .now-page__foot a {
    color: var(--text-tertiary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .now-page__foot a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
