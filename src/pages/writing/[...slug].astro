---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { ArrowLeft, ArrowRight } from "lucide-astro"
import BackLink from "../../components/BackLink.astro"
import NewsletterForm from "../../components/NewsletterForm.astro"
import PageLayout from "../../layouts/PageLayout.astro"
import { getBacklinksFor } from "../../lib/backlinks"
import { getAllWriting } from "../../lib/content"
import { computeReadingTime } from "../../lib/readingTime"

export async function getStaticPaths() {
  const all = await getAllWriting()
  return all.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      collection: entry.collection,
      prev: index < all.length - 1 ? all[index + 1] : null,
      next: index > 0 ? all[index - 1] : null,
    },
  }))
}

type AnyWriting = CollectionEntry<"writing"> | CollectionEntry<"blog">

type Props = {
  entry: AnyWriting
  collection: "writing" | "blog"
  prev: AnyWriting | null
  next: AnyWriting | null
}

const { entry, prev, next } = Astro.props as Props
const { Content } = await entry.render()
const readingTime = computeReadingTime(entry.body)
const backlinks = await getBacklinksFor(entry.slug)

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.heroImage}
>
  <article class="essay container" data-pagefind-body data-pagefind-filter="type:writing">
    <BackLink href="/writing" label="Writing" />
    <header class="essay__head">
      <p class="essay__meta">
        <time>{formatDate(new Date(entry.data.date))}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime}</span>
      </p>
      <h1>{entry.data.title}</h1>
      {entry.data.description ? <p class="essay__lede">{entry.data.description}</p> : null}
    </header>

    {
      entry.data.heroImage ? (
        <div class="essay__hero">
          <Image
            width={1280}
            height={640}
            src={entry.data.heroImage}
            alt={entry.data.imageAlt ?? entry.data.title}
            style="max-height: 480px; object-fit: cover;"
          />
        </div>
      ) : null
    }

    <div class="prose">
      <Content />
    </div>

    {
      prev || next ? (
        <nav class="post-nav" aria-label="Adjacent posts">
          {prev ? (
            <a href={`/writing/${prev.slug}`} class="post-nav__link post-nav__link--prev">
              <span class="post-nav__label"><ArrowLeft size={12} /> Previous</span>
              <span class="post-nav__title">{prev.data.title}</span>
            </a>
          ) : <span />}
          {next ? (
            <a href={`/writing/${next.slug}`} class="post-nav__link post-nav__link--next">
              <span class="post-nav__label">Next <ArrowRight size={12} /></span>
              <span class="post-nav__title">{next.data.title}</span>
            </a>
          ) : null}
        </nav>
      ) : null
    }

    {
      backlinks.length > 0 ? (
        <aside class="essay__backlinks">
          <h2>Linked notes</h2>
          <ul>
            {backlinks.map((b) => (
              <li>
                <a href={b.href}>{b.fromTitle}</a>
                <span class="essay__backlinks-type">{b.collection}</span>
              </li>
            ))}
          </ul>
        </aside>
      ) : null
    }

    <aside class="essay__newsletter">
      <NewsletterForm variant="card" />
    </aside>
  </article>
</PageLayout>

<style>
  .essay {
    padding-top: 56px;
    padding-bottom: 32px;
  }
  .essay__head {
    margin: 0 0 32px;
  }
  .essay__meta {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    color: var(--text-tertiary);
    margin: 0 0 16px;
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .essay__head h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    font-weight: 400;
    line-height: var(--lh-heading);
    color: var(--text-primary);
    margin: 0 0 16px;
  }
  .essay__lede {
    color: var(--text-secondary);
    font-size: var(--fs-lede);
    line-height: var(--lh-base);
    margin: 0;
  }
  .essay__hero {
    margin: 0 0 40px;
  }
  .essay__hero :global(img) {
    width: 100%;
    border-radius: 12px;
    display: block;
  }
  .essay__backlinks {
    margin: 56px 0 24px;
    border-top: 1px solid var(--border-subtle);
    padding-top: 24px;
  }
  .essay__backlinks h2 {
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-family: var(--font-mono);
    margin: 0 0 12px;
  }
  .essay__backlinks ul {
    list-style: none;
    padding: 0;
  }
  .essay__backlinks li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 0;
  }
  .essay__backlinks a {
    color: var(--text-primary);
  }
  .essay__backlinks a:hover {
    color: var(--accent);
  }
  .essay__backlinks-type {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
  }
  .essay__newsletter {
    margin-top: 48px;
  }
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border-subtle);
  }
  .post-nav__link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 16px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    transition: border-color 200ms ease, transform 150ms ease;
    color: inherit;
    min-width: 0;
  }
  .post-nav__link:hover {
    border-color: var(--border-emphasis);
    transform: translateY(-2px);
  }
  .post-nav__link--next {
    text-align: right;
    align-items: flex-end;
  }
  .post-nav__label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .post-nav__title {
    color: var(--text-primary);
    font-size: var(--fs-meta);
    font-weight: 500;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .post-nav__link:hover .post-nav__title {
    color: var(--accent);
  }
  @media (max-width: 560px) {
    .post-nav { grid-template-columns: 1fr; }
    .post-nav__link--next { text-align: left; align-items: flex-start; }
  }
</style>
